{
  "id": "astral-bridge",
  "name": "Astral-Manga Bridge",
  "version": "1.0.5",
  "language": "typescript",
  "type": "plugin",
  "description": "Solves Cloudflare challenge for astral-manga.fr manga provider",
  "author": "eren",
  "icon": "",
  "lang": "en",
  "payloadURI": "https://raw.githubusercontent.com/lebgdu543/seanime-pl/6391534fca6dfeae794114ed541228dece2d9b42/plugins/astral-bridge/code.ts",
  "manifestURI": "https://raw.githubusercontent.com/lebgdu543/seanime-pl/refs/heads/main/plugins/astral-bridge/manifest.json",
  "plugin": {
    "version": "1",
    "permissions": {
      "scopes": ["storage"],
      "allow": {
        "networkAccess": {
          "allowedDomains": ["astral-manga.fr", "*.astral-manga.fr"],
          "reasoning": "Required to fetch Cloudflare clearance cookies"
        }
      }
    }
  }
}
